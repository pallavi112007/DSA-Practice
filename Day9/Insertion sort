import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
	    int[] arr={10,20,15,30,25};
	    int n=arr.length;
	    for(int i=1;i<n;i++)
	    {
	    int k=arr[i];
	    int j=i-1;
	    while(j>=0 && arr[j]>k)
	    {
	        arr[j+1]=arr[j];
	        j--;
	    }
	    arr[j+1]=k;
	    }
	    for(int i=0;i<n;i++)
	    {
	        System.out.print(arr[i]+" ");
	    }
	}
}
