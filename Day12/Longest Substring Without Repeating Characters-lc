class Solution {
    public int lengthOfLongestSubstring(String s) {
        int max=0;
        for(int i=0;i<s.length();i++)
        {
            boolean visited[]=new boolean[256];
            int count=0;
            for(int j=i;j<s.length();j++)
            {
                if(visited[s.charAt(j)]==true)
                break;
            visited[s.charAt(j)]=true;
            count++;
            max=Math.max(max,count);
            }
        }
        return max;
        
    }

}
