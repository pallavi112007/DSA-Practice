import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
	    int[] arr={100, 80, 60, 70, 60, 75, 85};
	    for(int i=0;i<arr.length;i++)
	    {
	        int count=1;
	        for(int j=i;j>=0;j--)
	        {
	            if(arr[i]>arr[j])
	            {
	                count++;
	            }
	        }
	        System.out.print(count+" ");
	    }
	}
}
