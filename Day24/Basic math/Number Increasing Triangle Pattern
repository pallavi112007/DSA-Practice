import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		Scanner sc=new Scanner(System.in);
		int n=sc.nextInt();
		for(int i=1;i<=n;i++)
		{
		    for(int j=1;j<=i;j++)
		    {
		      System.out.print(j); //If we take i in place of j  then output like output2.
		    }
		    
		    System.out.println();
		}
	}
}
