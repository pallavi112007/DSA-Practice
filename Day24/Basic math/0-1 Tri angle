import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		Scanner sc=new Scanner(System.in);
		int n=sc.nextInt();
		int number=1;
		for(int i=1;i<=n;i++)
		{
		    for(int j=1;j<=i;j++)
		    {
		        if((i+j)%2==0)
		        System.out.print("1");
		        else
		        {
		            System.out.print("0");
		        }
		    }
		    System.out.println();
		}
	}
}
