import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		Scanner sc=new Scanner(System.in);
		int sum=0;
		int n=sc.nextInt();
		for(int i=1;i<n;i++)
		{
		    if(n%i==0)
		    {
		        sum+=i;
		    }
		}
		if(sum==n)
		{
		    System.out.println("Pefcet number");
		}
		else
		{
		    System.out.println("Not a perfect number");
		}

	}
}
