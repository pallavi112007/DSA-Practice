class Solution {
    public int maxSubarrayXOR(int[] arr, int k) {
        int n=0;
        int max=0;
        // code here
        for(int i=0;i<k;i++)
        {
            n^=arr[i];
        }
        max=n;
        for(int i=k;i<arr.length;i++)
        {
            n^=arr[i]^arr[i-k];
            if(max<n)
            {
                max=n;
            }
        }
        return max;
    }
}
