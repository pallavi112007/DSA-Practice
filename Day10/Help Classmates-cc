class Solution {
    public static int[] help_classmate(int arr[], int n) {
        int[] res=new int[n];
        for(int i=0;i<n;i++)
        {
            res[i]=-1;
        }
        for(int i=0;i<n;i++)
        {
            for(int j=i+1;j<n;j++)
            {
                if(arr[i]>arr[j])
                {
                    res[i]=arr[j];
                    break;
                }
            }
        }
        return res;
        // Your code goes here
    }
}
