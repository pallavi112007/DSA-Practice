class Solution {
    public int countSubarrays(int[] arr) {
        // code here
        int n=arr.length;
        int count=0;
        for(int i=0;i<n;i++)
        {
            for(int j=i;j<n;j++)
            {
                if(arr[j]<arr[i])
                {
                    break;
                }
                count++;
            }
        }
        return count;
    }
}
