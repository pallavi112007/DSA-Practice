class Solution {
    public int sumSubMins(int[] arr) {
        int n=arr.length;
        int sum=0;
        for(int i=0;i<n;i++)
        {
            int min=arr[i];
            for(int j=i;j<n;j++)
            {
                min=Math.min(arr[j],min);
                sum+=min;
            }
        }
        return sum;
    }
}
