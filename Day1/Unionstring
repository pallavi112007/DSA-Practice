import java.util.*;
class Union
{
  public static ArrayList<Integer> findUnion(int[] a,int[] b)
  {
    HashSet<Integer> set=new HashSet<>();
    for(int i=0;i<a.length;i++)
    {
      set.add(a[i]);
    }
    for(int j=0;j<b.length;j++)
    {
      set.add(b[i]);
    }
    ArrayList<Integer> res=new ArrayList<>(set);
    return res;
    }
}
